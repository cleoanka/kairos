# Kairos environment — copy to .env and fill in what you use. NEVER commit .env.
# The System-1 perception, the causal bridge, and the deterministic cognitive
# loop need NONE of these. Only `--mode llm` / `kairos reason` (System-2) need an
# LLM key; the vendor keys are optional and only broaden System-2's data.

# --- System-2 LLM providers (need at least one for `reason` / `--mode llm`) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=

# --- System-2 model / behavior overrides (optional; see default_config.py) ---
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
# TRADINGAGENTS_OUTPUT_LANGUAGE=English
# TRADINGAGENTS_MAX_DEBATE_ROUNDS=1

# --- System-2 optional data vendors ---
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- System-1 live market data (optional; only for `kairos web --live` / real ingest) ---
# Public Bybit WS needs no key. Real-money routing is refused without explicit
# operator confirmation; keys below are only for authenticated feeds you add.
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
